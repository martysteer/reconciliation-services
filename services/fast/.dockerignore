# Build context hygiene -- keep the Docker build context small.
# NOTE: FASTAll.marcxml.zip at the service root is intentionally NOT
# excluded: it seeds the build when the OCLC download is Cloudflare-blocked.
data/
.venv/
venv/
__pycache__/
*.py[cod]
.python-version
.git/
.gitignore
.dockerignore
.DS_Store
.idea/
.vscode/
*.log
README.md
xslt/docs/
